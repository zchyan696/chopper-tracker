# Normalize line endings: LF in repo, CRLF on Windows checkout
* text=auto

# Explicit text files
*.html text eol=lf
*.css  text eol=lf
*.js   text eol=lf
*.json text eol=lf
*.md   text eol=lf
*.bat  text eol=crlf
*.py   text eol=lf

# Binary files
*.wav  binary
*.mp3  binary
*.aif  binary
*.aiff binary
*.ogg  binary
*.flac binary
*.mid  binary
*.png  binary
*.jpg  binary
*.ico  binary
